# 舟友同好集会地图 —— 环境变量示例
# 复制为 .env 并填写真实值（或使用系统环境变量 / 命令行前缀）

# 网页标题
APP_TITLE=舟友同好集会地图

# 服务端口
PORT=3000

# 高德地图（Web端 JS API）凭据 —— 前端地图渲染用
# 申请地址：https://console.amap.com/dev/key/app （创建「Web端(JS API)」类型 Key）
AMAP_KEY=
# 高德 2.0 安全密钥（创建 Key 时一并生成，名为「安全密钥」）
AMAP_SECURITY_CODE=

# 高德「Web 服务」Key —— 服务端批量地理编码用（与上面 JS API Key 不同类型！）
# 同一控制台创建 Key 时，服务平台选「Web 服务」。配置后运行 npm run geocode
AMAP_WEB_KEY=
# 若为该 Key 开启「数字签名」，填私钥；未开启留空
AMAP_WEB_SECRET=

# 会话签名密钥（请改成随机长字符串）
SESSION_SECRET=arknights-only-map-change-me-please

# 数据库文件路径（可选，默认 data/app.db）
# DB_PATH=./data/app.db
